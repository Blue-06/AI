import os
import re
import json
import hashlib
from typing import List, Dict

import fitz
import chromadb
import numpy as np
import streamlit as st

from openai import OpenAI
from sklearn.linear_model import LinearRegression


# ============================================================
# CONFIGURATION
# ============================================================

LLM_API_KEY = os.getenv("LLM_API_KEY")
LLM_BASE_URL = os.getenv(
    "LLM_BASE_URL",
    "https://generativelanguage.googleapis.com/v1beta/openai/"
)
LLM_MODEL = os.getenv("LLM_MODEL", "gemini-2.5-flash")
EMBEDDING_MODEL = os.getenv(
    "EMBEDDING_MODEL",
    "gemini-embedding-001"
)

if not LLM_API_KEY:
    st.error(
        "LLM_API_KEY is not configured.\n\n"
        "Set it in PowerShell before running the app."
    )
    st.stop()


# ============================================================
# LLM CLIENT
# ============================================================

client = OpenAI(
    api_key=LLM_API_KEY,
    base_url=LLM_BASE_URL
)


# ============================================================
# STREAMLIT CONFIGURATION
# ============================================================

st.set_page_config(
    page_title="TrustRAG",
    page_icon="🛡️",
    layout="wide"
)

st.title("🛡️ TrustRAG")
st.caption(
    "Evidence-Based PDF Intelligence Agent "
    "with RAG, Guardrails, Confidence, Citations and Forecasting"
)


# ============================================================
# SESSION STATE
# ============================================================

if "processed" not in st.session_state:
    st.session_state.processed = False

if "document_id" not in st.session_state:
    st.session_state.document_id = None

if "messages" not in st.session_state:
    st.session_state.messages = []

if "summary" not in st.session_state:
    st.session_state.summary = None

if "chunks" not in st.session_state:
    st.session_state.chunks = []

if "collection" not in st.session_state:
    st.session_state.collection = None

if "cache" not in st.session_state:
    st.session_state.cache = {}

if "token_stats" not in st.session_state:
    st.session_state.token_stats = {
        "estimated_context_tokens": 0,
        "llm_calls": 0
    }


# ============================================================
# PDF PROCESSING
# ============================================================

def extract_pdf_pages(pdf_bytes: bytes) -> List[Dict]:

    document = fitz.open(
        stream=pdf_bytes,
        filetype="pdf"
    )

    pages = []

    for page_number, page in enumerate(document):

        text = page.get_text("text")

        if text and text.strip():

            pages.append({
                "page": page_number + 1,
                "text": text.strip(),
                "source": "uploaded_document.pdf"
            })

    return pages


def create_chunks(
    pages: List[Dict],
    chunk_size: int = 1200,
    overlap: int = 150
) -> List[Dict]:

    chunks = []

    chunk_counter = 0

    for page in pages:

        text = page["text"]

        start = 0

        while start < len(text):

            end = start + chunk_size

            chunk_text = text[start:end]

            if chunk_text.strip():

                chunks.append({
                    "chunk_id": f"chunk_{chunk_counter}",
                    "text": chunk_text.strip(),
                    "page": page["page"],
                    "source": page["source"]
                })

                chunk_counter += 1

            start = end - overlap

    return chunks


# ============================================================
# EMBEDDINGS
# ============================================================

def create_embedding(text: str) -> List[float]:

    response = client.embeddings.create(
        model=EMBEDDING_MODEL,
        input=text
    )

    return response.data[0].embedding


# ============================================================
# VECTOR DATABASE
# ============================================================

def get_vector_collection(document_id: str):

    chroma_client = chromadb.PersistentClient(
        path="./chroma_db"
    )

    collection_name = f"document_{document_id}"

    collection = chroma_client.get_or_create_collection(
        name=collection_name
    )

    return collection


def store_chunks(
    chunks: List[Dict],
    collection
):

    ids = []
    documents = []
    embeddings = []
    metadatas = []

    progress = st.progress(0)

    for index, chunk in enumerate(chunks):

        ids.append(chunk["chunk_id"])

        documents.append(chunk["text"])

        embeddings.append(
            create_embedding(chunk["text"])
        )

        metadatas.append({
            "page": chunk["page"],
            "source": chunk["source"]
        })

        progress.progress(
            (index + 1) / len(chunks)
        )

    collection.upsert(
        ids=ids,
        documents=documents,
        embeddings=embeddings,
        metadatas=metadatas
    )

    progress.empty()


def retrieve_chunks(
    question: str,
    collection,
    top_k: int = 4
):

    query_embedding = create_embedding(question)

    results = collection.query(
        query_embeddings=[query_embedding],
        n_results=top_k,
        include=[
            "documents",
            "metadatas",
            "distances"
        ]
    )

    retrieved = []

    if not results["documents"]:
        return retrieved

    for index, text in enumerate(
        results["documents"][0]
    ):

        distance = results["distances"][0][index]

        # Approximate normalized similarity
        similarity = max(
            0.0,
            min(
                1.0,
                1.0 - distance
            )
        )

        retrieved.append({

            "chunk_id": results["ids"][0][index],

            "text": text,

            "page": results["metadatas"][0][index]["page"],

            "source": results["metadatas"][0][index]["source"],

            "similarity": similarity
        })

    return retrieved


# ============================================================
# LLM FUNCTIONS
# ============================================================

def call_llm(
    prompt: str,
    temperature: float = 0
):

    st.session_state.token_stats["llm_calls"] += 1

    response = client.chat.completions.create(

        model=LLM_MODEL,

        messages=[

            {
                "role": "system",
                "content": (
                    "You are TrustRAG, an evidence-based "
                    "document intelligence assistant."
                )
            },

            {
                "role": "user",
                "content": prompt
            }

        ],

        temperature=temperature
    )

    return response.choices[0].message.content


def classify_question(question: str) -> str:

    prompt = f"""
Classify this user question into exactly one category.

Categories:

RAG
- Question asks about facts in the uploaded document.

SUMMARY
- User asks for summary, overview or explanation of the document.

FORECAST
- User asks for future prediction, projection or forecasting.

Return ONLY one word:
RAG
SUMMARY
or
FORECAST

Question:
{question}
"""

    result = call_llm(prompt)

    result = result.strip().upper()

    if "FORECAST" in result:
        return "FORECAST"

    if "SUMMARY" in result:
        return "SUMMARY"

    return "RAG"


def generate_summary(
    chunks: List[Dict]
):

    # Token optimization:
    # summarize only a bounded amount of context.
    selected_chunks = chunks[:40]

    context = "\n\n".join(

        f"PAGE {chunk['page']}:\n"
        f"{chunk['text']}"

        for chunk in selected_chunks
    )

    prompt = f"""
Create an executive summary of this uploaded document.

Include:

1. Main purpose/topic
2. Key facts
3. Important numbers
4. Major trends
5. Risks or important observations

Use ONLY the document content.

Do not invent information.

DOCUMENT CONTENT:

{context}
"""

    return call_llm(prompt)


def answer_question(
    question: str,
    retrieved_chunks: List[Dict]
):

    context = "\n\n".join(

        f"""
CHUNK_ID: {chunk['chunk_id']}
PAGE: {chunk['page']}
SOURCE: {chunk['source']}

CONTENT:
{chunk['text']}
"""

        for chunk in retrieved_chunks
    )

    prompt = f"""
You are an evidence-based PDF assistant.

Answer the question ONLY using the provided evidence.

STRICT RULES:

1. Do not use external knowledge.
2. Do not invent facts.
3. Do not invent numbers.
4. Do not invent dates.
5. Do not invent citations.
6. If the answer is not supported, say:

"I cannot find sufficient evidence in the uploaded document."

7. Select only source IDs that genuinely support your answer.

QUESTION:

{question}

EVIDENCE:

{context}

Return ONLY valid JSON:

{{
    "answer": "your answer",
    "source_ids": ["chunk_1"]
}}
"""

    raw_response = call_llm(prompt)

    try:

        parsed = json.loads(raw_response)

        return {

            "answer": parsed.get(
                "answer",
                "I cannot find sufficient evidence in the uploaded document."
            ),

            "source_ids": parsed.get(
                "source_ids",
                []
            )

        }

    except Exception:

        return {

            "answer": (
                "I could not validate the model response. "
                "Please try the question again."
            ),

            "source_ids": []

        }


# ============================================================
# GUARDRAILS
# ============================================================

def input_guardrail(question: str):

    if not question.strip():

        return False, "Please enter a question."

    dangerous_terms = [

        "password",

        "api key",

        "secret key",

        "private key",

        "malware",

        "ransomware"

    ]

    question_lower = question.lower()

    for term in dangerous_terms:

        if term in question_lower:

            return False, (
                "I cannot process this request because it "
                "appears to request sensitive or unsafe information."
            )

    return True, ""


def retrieval_guardrail(
    retrieved_chunks: List[Dict],
    threshold: float = 0.45
):

    if not retrieved_chunks:

        return False

    best_similarity = retrieved_chunks[0]["similarity"]

    return best_similarity >= threshold


def validate_answer(
    response: Dict,
    retrieved_chunks: List[Dict]
):

    answer = response.get(
        "answer",
        ""
    )

    source_ids = response.get(
        "source_ids",
        []
    )

    valid_ids = {

        chunk["chunk_id"]

        for chunk in retrieved_chunks

    }

    valid_source_ids = [

        source_id

        for source_id in source_ids

        if source_id in valid_ids

    ]

    if not answer:

        return {

            "supported": False,

            "evidence_score": 0.0,

            "citation_score": 0.0

        }

    if not valid_source_ids:

        return {

            "supported": False,

            "evidence_score": 0.0,

            "citation_score": 0.0

        }

    return {

        "supported": True,

        "evidence_score": 0.85,

        "citation_score": (

            len(valid_source_ids)

            /

            max(
                1,
                len(source_ids)
            )

        )

    }


def calculate_confidence(
    retrieval_score: float,
    evidence_score: float,
    citation_score: float
):

    score = (

        retrieval_score * 0.5

        +

        evidence_score * 0.3

        +

        citation_score * 0.2

    )

    return round(

        max(
            0.0,
            min(
                1.0,
                score
            )
        )

        *

        100,

        2

    )


# ============================================================
# FORECASTING
# ============================================================

def extract_time_series(
    chunks: List[Dict]
):

    full_text = "\n".join(

        chunk["text"]

        for chunk in chunks

    )

    patterns = [

        r"(20\d{2})\s*[:\-]\s*[₹$€£]?\s*([0-9]+(?:\.[0-9]+)?)",

        r"(20\d{2})\s+[₹$€£]?\s*([0-9]+(?:\.[0-9]+)?)"

    ]

    data = []

    for pattern in patterns:

        matches = re.findall(

            pattern,

            full_text

        )

        for year, value in matches:

            data.append({

                "year": int(year),

                "value": float(value)

            })

    unique = {}

    for item in data:

        unique[item["year"]] = item["value"]

    return [

        {

            "year": year,

            "value": value

        }

        for year, value

        in sorted(
            unique.items()
        )

    ]


def forecast_time_series(
    data: List[Dict]
):

    if len(data) < 3:

        return None

    X = np.array(

        [

            item["year"]

            for item in data

        ]

    ).reshape(
        -1,
        1
    )

    y = np.array(

        [

            item["value"]

            for item in data

        ]

    )

    model = LinearRegression()

    model.fit(
        X,
        y
    )

    next_year = max(

        item["year"]

        for item in data

    ) + 1

    prediction = model.predict(

        np.array(

            [

                [

                    next_year

                ]

            ]

        )

    )[0]

    r2 = model.score(
        X,
        y
    )

    confidence = max(

        0.0,

        min(
            1.0,
            r2
        )

    )

    return {

        "next_year": next_year,

        "prediction": prediction,

        "confidence": confidence * 100

    }


