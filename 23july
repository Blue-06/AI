import numpy as np
from sklearn.linear_model import LinearRegression


def forecast(values):

    X = np.array(range(len(values))).reshape(-1, 1)

    y = np.array(values)

    model = LinearRegression()

    model.fit(X, y)

    next_period = np.array([[len(values)]])

    prediction = model.predict(next_period)

    return prediction[0]
