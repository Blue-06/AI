    if not docs:
        return RetrievalResult("", [], 0.0, 0, True, "No evidence retrieved.")

    accepted = []
    for doc_text, meta, dist in zip(docs, metas, distances):
        if dist is None:
            continue
        if dist <= distance_threshold:
            accepted.append((doc_text, meta, float(dist)))

    if not accepted:
        return RetrievalResult("", [], 0.0, 0, True, "Retrieved evidence was below quality threshold.")

    accepted.sort(key=lambda x: x[2])
    context_blocks = []
    citations: List[Dict[str, object]] = []
    total_chars = 0
    dist_values = []
    for doc_text, meta, dist in accepted:
        snippet = doc_text[:800]
        candidate = f"[Page {meta['page']}, Chunk {meta['chunk']}] {snippet}"
        new_total = total_chars + len(candidate)
        if new_total > max_context_chars:
            break
        context_blocks.append(candidate)
        citations.append(
            {
                "source": meta["source"],
                "page": int(meta["page"]),
                "chunk": int(meta["chunk"]),
                "distance": round(dist, 4),
                # Snippet acts as a quick locator for where evidence came from.
                "snippet": snippet[:160],
            }
        )
        dist_values.append(dist)
        total_chars = new_total

    if not context_blocks:
        return RetrievalResult("", [], 0.0, 0, True, "Context budget too small to include evidence.")

    avg_dist = float(np.mean(dist_values)) if dist_values else 1.0
    confidence = max(0.0, min(1.0, 1.0 - avg_dist))
    unique_citations = []
    seen = set()
    for citation in citations:
        # De-duplicate by exact source/page/chunk location.
        key = (citation["source"], citation["page"], citation["chunk"])
        if key in seen:
            continue
        seen.add(key)
        unique_citations.append(citation)
    return RetrievalResult(
        context="\n\n".join(context_blocks),
        citations=unique_citations,
        confidence=confidence,
        hit_count=len(context_blocks),
        rejected=False,
        rejection_reason="",
    )


def extract_historical_values(text: str) -> List[float]:
    """Extract ordered numeric values from retrieved context for forecasting."""

    values = re.findall(r"(?<!\w)(?:\d{1,3}(?:,\d{3})*|\d+)(?:\.\d+)?(?!\w)", text)
    parsed = []
    for value in values:
        try:
            parsed.append(float(value.replace(",", "")))
        except ValueError:
            continue
    return parsed


def basic_linear_forecast(series: List[float], steps: int = 3) -> List[float]:
    """Simple trend forecast using linear regression (numpy polyfit)."""

    if len(series) < 3:
        return []
    x = np.arange(len(series), dtype=float)
    y = np.array(series, dtype=float)
    m, b = np.polyfit(x, y, 1)
    future_x = np.arange(len(series), len(series) + steps, dtype=float)
    preds = (m * future_x + b).tolist()
    return [round(v, 3) for v in preds]


def validate_output(answer: str, citations: List[Dict[str, object]]) -> Tuple[bool, str]:
    """Validate non-empty output and check that mentioned pages exist in retrieved citations."""

    if not answer.strip():
        return False, "Model returned an empty answer."
    if not citations:
        return False, "No citations available for validation."

    # If model references explicit page numbers, ensure they were in retrieval evidence.
    pages_in_answer = set(re.findall(r"[Pp]age\s+(\d+)", answer))
    cited_pages = set()
    for citation in citations:
        page = citation.get("page")
        if page is not None:
            cited_pages.add(str(page))

    if pages_in_answer and not pages_in_answer.issubset(cited_pages):
        return False, "Answer cited page numbers that were not in retrieved evidence."

    return True, ""


def refusal_message(reason: str) -> str:
    """Consistent refusal string when evidence or validation fails."""

    return (
        "I cannot answer reliably from the uploaded document. "
        f"Reason: {reason} "
        "Please ask a question closer to the document text or upload a more relevant PDF."
    )


def build_pdf_page_link(pdf_b64: Optional[str], page: int) -> Optional[str]:
    """Create a browser-openable PDF link that jumps to a specific page when possible."""

    if not pdf_b64:
        return None
    safe_page = max(1, int(page))
    return f"data:application/pdf;base64,{pdf_b64}#page={safe_page}"


def render_response_cards(intent: str, confidence: float, chunks: int, citations: List[Dict[str, object]]) -> None:
    """Render confidence and citations in a simplified UI."""

    confidence_100 = round(confidence * 100)
    st.metric("Confidence", f"{confidence_100}")
    st.caption("Confidence guide: Good >= 80 | Medium 60-79 | Low < 60")

    if citations:
        st.markdown("**Citations**")
        pdf_b64 = st.session_state.get("pdf_b64")
        for idx, citation in enumerate(citations, start=1):
            source = citation.get("source", "unknown")
            page = citation.get("page", "?")
            snippet = citation.get("snippet", "")
            st.info(
                f"[{idx}] {source} | Page {page}\n\n"
                f"Preview: {snippet}..."
            )

            # Link opens embedded PDF and jumps to cited page (browser support dependent).
            if isinstance(page, int):
                page_link = build_pdf_page_link(pdf_b64, page)
                if page_link:
                    st.markdown(f"[View Page {page}]({page_link})")


