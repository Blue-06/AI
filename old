uploaded_file = st.file_uploader("Upload PDF", type=["pdf"])

if uploaded_file is not None:
    # Re-index only when file content changes.
    pdf_bytes = uploaded_file.read()
    sha = file_sha256(pdf_bytes)

    if st.session_state.last_uploaded_sha != sha:
        with st.spinner("Extracting text with PyMuPDF and indexing in ChromaDB..."):
            texts, metas = extract_pdf_chunks(pdf_bytes, uploaded_file.name)
            if not texts:
                st.error("No extractable text found in this PDF.")
                st.stop()

            client = chromadb.PersistentClient(path="chroma_store")
            collection_name = make_collection_name(sha)

            existing = [c.name for c in client.list_collections()]
            if collection_name in existing:
                # Replace previous index for same document hash.
                client.delete_collection(name=collection_name)

            collection = client.create_collection(
                name=collection_name,
                embedding_function=OpenAIEmbeddingFn(llm_layer),
                metadata={"hnsw:space": "cosine"},
            )

            ids = [f"{collection_name}_{i}" for i in range(len(texts))]
            collection.add(documents=texts, metadatas=metas, ids=ids)

            st.session_state.collection_name = collection_name
            st.session_state.last_uploaded_sha = sha
            st.session_state.doc_ready = True
            st.session_state.chat_history = []
            # Store PDF in-memory as base64 for page-jump citation links.
            st.session_state.pdf_b64 = base64.b64encode(pdf_bytes).decode("ascii")

        st.success(f"Indexed {len(texts)} chunks from {uploaded_file.name}.")

if st.session_state.doc_ready and st.session_state.collection_name:
    chroma_client = chromadb.PersistentClient(path="chroma_store")
    collection = chroma_client.get_collection(
        name=st.session_state.collection_name,
        embedding_function=OpenAIEmbeddingFn(llm_layer),
    )

    st.subheader("Interactive Q&A")
    for item in st.session_state.chat_history:
        st.markdown(f"You: {item['q']}")
        st.markdown(f"Assistant: {item['a']}")
        render_response_cards(
            intent=item["intent"],
            confidence=item["confidence"],
            chunks=item["chunks"],
            citations=item["citations"],
        )
        render_debug_panel(item["debug"])
        st.divider()

    # One-click prompt starters help run a fast hackathon demo.
    st.markdown("**Sample questions**")
    sample_cols = st.columns(3)
    sample_q = None
    if sample_cols[0].button("Summarize key findings"):
        sample_q = "Summarize the key findings from this PDF in simple language."
    if sample_cols[1].button("List important warnings"):
        sample_q = "What warning signs or important cautions are mentioned?"
    if sample_cols[2].button("Forecast trend from numbers"):
        sample_q = "Forecast the next 3 values from the historical numbers in this document."

    question = st.text_input("Ask a question about the uploaded PDF")
    ask = st.button("Ask")

    if ask or sample_q:
        raw_question = (sample_q or question or "").strip()

        # Input guardrails
        if not raw_question:
            st.warning("Please enter a question.")
            st.stop()
        if len(raw_question) > 1200:
            st.warning("Question too long. Please keep it under 1200 characters.")
            st.stop()
        blocked_reason = contains_blocked_pattern(raw_question)
        if blocked_reason:
            st.warning(f"Question blocked by input guardrails: {blocked_reason}.")
            st.stop()

        intent = route_intent(raw_question)

        # Retrieve context + confidence from vector store.
        retrieval = build_context_and_confidence(
            collection=collection,
            query=raw_question,
            k=top_k,
            distance_threshold=threshold,
            max_context_chars=max_context_chars,
        )

        # Retrieval threshold guardrail and refusal behavior
        if retrieval.rejected:
            answer = refusal_message(retrieval.rejection_reason)
            confidence = 0.0
            chunks = 0
            citations = []
        else:
            if intent == "forecast":
                # Forecast path: derive a numeric series from retrieved evidence.
                history = extract_historical_values(retrieval.context)
                preds = basic_linear_forecast(history, steps=3)
                if not preds:
                    answer = refusal_message(
                        "Forecasting requires at least 3 historical numeric values in retrieved evidence."
                    )
                else:
                    answer = (
                        "Forecast generated from retrieved historical values.\n"
                        f"Recent values used (sample): {history[:10]}\n"
                        f"Next 3 projected values: {preds}"
                    )
            else:
                # QA path: LLM answers strictly from retrieved context.
                system_prompt = (
                    "You are a precise assistant. Use ONLY the provided context. "
                    "If evidence is insufficient, say exactly: INSUFFICIENT_EVIDENCE. "
                    "Keep answer concise and factual."
                )
                user_prompt = (
                    f"Question:\n{raw_question}\n\n"
                    f"Context:\n{retrieval.context}\n\n"
                    "Answer in 3-8 lines."
                )
                answer = llm_layer.chat(system_prompt=system_prompt, user_prompt=user_prompt, temperature=0.0)

                if "INSUFFICIENT_EVIDENCE" in answer.upper():
                    answer = refusal_message("Model could not find sufficient evidence in retrieved context.")

            # Output/citation validation
            valid, validation_reason = validate_output(answer, retrieval.citations)
            if not valid:
                answer = refusal_message(validation_reason)

            confidence = retrieval.confidence
            chunks = retrieval.hit_count
            citations = retrieval.citations

        debug = {
            "question": raw_question,
            "intent": intent,
            "top_k": top_k,
            "distance_threshold": threshold,
            "max_context_chars": max_context_chars,
            "retrieval_rejected": retrieval.rejected,
            "rejection_reason": retrieval.rejection_reason,
            "confidence": round(confidence * 100),
            "citations_count": len(citations),
            "citation_pages": [c.get("page") for c in citations],
        }

        st.session_state.chat_history.append(
            {
                "q": raw_question,
                "a": answer,
                "intent": intent,
                "confidence": confidence,
                "chunks": chunks,
                "citations": citations,
                "debug": debug,
            }
        )
        # Rerun so newly appended answer renders at top with cards.
        st.rerun()

st.caption("Responses are retrieval-grounded and include guardrails; verify critical decisions with original sources.")

