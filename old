@dataclass
class RetrievalResult:
    """Structured retrieval payload passed from retriever to answer stage."""

    context: str
    citations: List[Dict[str, object]]
    confidence: float
    hit_count: int
    rejected: bool
    rejection_reason: str


class OpenAICompatibleLayer:
    """Model-agnostic wrapper for OpenAI-compatible chat and embeddings endpoints."""

    def __init__(self, base_url: str, api_key: str, chat_model: str, embedding_model: str):
        # Any provider that supports OpenAI-compatible APIs can be plugged in here.
        self.client = OpenAI(base_url=base_url, api_key=api_key)
        self.chat_model = chat_model
        self.embedding_model = embedding_model

    def embed(self, texts: List[str]) -> List[List[float]]:
        """Create embeddings for a list of texts."""
        cleaned = [t.replace("\n", " ").strip() for t in texts]
        response = self.client.embeddings.create(model=self.embedding_model, input=cleaned)
        return [item.embedding for item in response.data]

    def chat(self, system_prompt: str, user_prompt: str, temperature: float = 0.1) -> str:
        """Send one chat completion request and return only the model text."""
        response = self.client.chat.completions.create(
            model=self.chat_model,
            temperature=temperature,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_prompt},
            ],
        )
        return response.choices[0].message.content or ""


class OpenAIEmbeddingFn(EmbeddingFunction):
    """Adapter so ChromaDB can call our custom embedding layer."""

    def __init__(self, llm_layer: OpenAICompatibleLayer):
        self.llm_layer = llm_layer

    def __call__(self, input: List[str]) -> List[List[float]]:
        return self.llm_layer.embed(list(input))


def init_state() -> None:
    """Initialize Streamlit session state keys used across reruns."""

    defaults = {
        "collection_name": None,
        "last_uploaded_sha": None,
        "chat_history": [],
        "doc_ready": False,
        "pdf_b64": None,
    }
    for key, value in defaults.items():
